{
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist",
  "env": {
    "NODE_ENV": "production",
    "VITE_API_URL": "https://vainateya.vercel.app/api"
  },
  "framework": "vite",
  "nodeVersion": "18.x",
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 30,
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
