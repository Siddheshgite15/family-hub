# Backend Environment Variables - Production Template
# Copy this file to .env and fill in your values with REAL credentials

# ============================================
# Server Configuration
# ============================================
PORT=5000
NODE_ENV=production

# ============================================
# Database Configuration - CHANGE THESE!
# ============================================
# Important: Use your own MongoDB cluster and credentials
# Do NOT commit real credentials to git
# Example format: mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/?appName=your_app_name
MONGODB_DB_NAME=family_hub

# ============================================
# Authentication & Security - CHANGE THESE!
# ============================================
# Use a strong, random secret key for JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_strong_random_secret_key_minimum_32_characters
JWT_EXPIRES_IN=7d

# ============================================
# Frontend Configuration
# ============================================
# URL where the Next.js/React frontend is hosted
FRONTEND_URL=http://localhost:5173
# Optional comma-separated extra CORS origins (LAN IPs, staging domains, etc.)
# CORS_ORIGINS=http://192.168.1.10:5173,https://staging.example.com

# ============================================
# Email Configuration (Optional but Recommended)
# ============================================
# For sending enquiry emails via SMTP
MAIL_SERVICE=gmail
MAIL_USER=school@example.com
MAIL_PASSWORD=your_app_password
SCHOOL_ADMIN_EMAIL=admin@school.edu
# Used by enquiry emails (see enquiryController); falls back to MAIL_USER
# SCHOOL_EMAIL=office@school.edu

# ============================================
# Logging & Monitoring (Optional)
# ============================================
# LOG_LEVEL=info
# SENTRY_DSN=your_sentry_dsn_here
