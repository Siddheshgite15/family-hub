# Frontend — copy to .env.local and adjust.

# API base URL including /api suffix.
# Local: leave unset to use Vite proxy to backend on port 9000 (see vite.config.ts).
# Production: set to your deployed API, e.g. https://your-project.vercel.app/api
# VITE_API_URL=http://localhost:9000/api

# ── School display & contact (public, safe for Vite bundle) ──
VITE_SCHOOL_DISPLAY_NAME_MR=वैनतेय प्राथमिक विद्या मंदिर
VITE_SCHOOL_HERO_TITLE_BASE_MR=वैनतेय प्राथमिक
VITE_SCHOOL_HERO_TITLE_ACCENT_MR=विद्या मंदिर
VITE_SCHOOL_SHORT_NAME_MR=वैनतेय
VITE_SCHOOL_TAGLINE_MR=निफाड, नाशिक
VITE_SCHOOL_LOCATION_MR=निफाड, ता. निफाड, जि. नाशिक
# Multiline OK in quotes in real .env files
VITE_SCHOOL_ADDRESS_MR=वैनतेय प्राथमिक विद्या मंदिर\nनिफाड, ता. निफाड, जि. नाशिक — 422303
VITE_SCHOOL_POSTAL_CODE=422303
VITE_SCHOOL_PHONE_DISPLAY=+९१ २२ २३५६ ६८९०
VITE_SCHOOL_PHONE_TEL=+912223566890
VITE_SCHOOL_EMAIL_GENERAL=info@vainateya.edu
VITE_SCHOOL_EMAIL_ADMISSIONS=admissions@vainateya.edu
# VITE_SCHOOL_WEBSITE_URL=https://example.com
VITE_SCHOOL_TRUSTEE_MR=न्या. रानडे विद्याप्रसारक मंडळ संचालित
VITE_SCHOOL_HERO_BADGE_MR=इयत्ता १ ली ते ४ थी • न्या. रानडे विद्याप्रसारक मंडळ संचालित, निफाड
VITE_SCHOOL_HERO_SUBTITLE_MR=मुलांच्या सर्वांगीण विकासासाठी पोषक वातावरण आणि उच्च दर्जाचे प्राथमिक शिक्षण.
VITE_SCHOOL_FOOTER_BLURB_MR=इयत्ता १ ली ते ४ थी — मुलांच्या उज्ज्वल भविष्यासाठी आणि सर्वांगीण विकासासाठी समर्पित संस्था.
# Google Maps embed + external link
# VITE_SCHOOL_MAP_EMBED_URL=https://www.google.com/maps/embed?...
# VITE_SCHOOL_MAP_EXTERNAL_URL=https://maps.google.com/?q=...
VITE_SCHOOL_MAP_CAPTION_MR=वैनतेय प्राथमिक विद्या मंदिर, निफाड
VITE_SCHOOL_COPYRIGHT_YEAR_MR=२०२६
